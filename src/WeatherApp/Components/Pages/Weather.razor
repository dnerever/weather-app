@page "/weather"
@rendermode InteractiveServer
@inject WeatherApp.Services.WeatherService WeatherService
@using WeatherApp.Models

<PageTitle>WeatherNow</PageTitle>

<div class="container mt-4" style="max-width: 500px;">
    <h1 class="mb-4">Weather Search</h1>

    <div class="mb-3">
        <input class="form-control" placeholder="Enter city name..."
            @bind="cityInput" @bind:event="oninput"
            @onkeydown="HandleKeyDown" />
        <button class="btn btn-primary" @onclick="SearchWeather">Search</button>
    </div>

    <ErrorBoundary>
        <ChildContent>
            @if (isLoading)
            {
                <div class="d-flex align-items-center gap-2">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    <span>Searching...</span>
                </div>
            }
            else if (errorMessage != null)
            {
                <p class="alert alert-danger">@errorMessage</p>
            }
            else if (weather?.Current != null && location != null)
            {
                <div class="card shadow-sm weather-card">
                    <div class="card-body">
                        <h3 class="card-title">@location.Name, @location.Country</h3>
                        <hr />
                        <p>Temperature: <strong>@GetDisplayTemp() @(isCelsius ? "°C" : "°F")</strong></p>
                        <button class="btn btn-sm btn-outline-secondary mt-1" @onclick="ToggleUnit">
                            Switch to @(isCelsius ? "°F" : "°C")
                        </button>
                        <p>Wind Speed: <strong>@weather.Current.WindSpeed10m km/h</strong></p>
                        <p class="fs-5">@WeatherCodeHelper.GetEmoji(weather.Current.WeatherCode) @WeatherCodeHelper.GetDescription(weather.Current.WeatherCode)</p>
                    </div>
                </div>
            }
        </ChildContent>
        <ErrorContent>
            <div class="alert alert-danger">
                Something went wrong loading weather data. Please try again.
            </div>
        </ErrorContent>
    </ErrorBoundary>
</div>

@code {
    private string cityInput = "";
    private bool isLoading = false;
    private string? errorMessage;
    private WeatherApp.Models.WeatherResponse? weather;
    private WeatherApp.Models.GeocodingResult? location;
    private bool isCelsius = true;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchWeather();
    }

    private async Task SearchWeather()
    {
        if (string.IsNullOrWhiteSpace(cityInput)) return;

        isLoading = true;
        errorMessage = null;
        weather = null;
        StateHasChanged();

        location = await WeatherService.GetLocationAsync(cityInput);

        if (location == null)
        {
            errorMessage = $"Could not find city: {cityInput}";
            isLoading = false;
            return;
        }

        weather = await WeatherService.GetWeatherAsync(location.Latitude, location.Longitude);

        isLoading = false;
    }

    private void ToggleUnit() => isCelsius = !isCelsius;

    private string GetDisplayTemp()
    {
        if (weather?.Current == null) return "";
        var temp = isCelsius
            ? weather.Current.Temperature2m
            : Math.Round(weather.Current.Temperature2m * 9 / 5 + 32, 1);
        return temp.ToString();
    }
}
